+
+
+class CausalAlphaProvider(Protocol):
+    """Alpha provider that receives no market rows after the decision index."""
+
+    @property
+    def identity_digest(self) -> str: ...
+
+    def predict(self, market: CausalMarketView) -> np.ndarray: ...
