[importlinter]
root_package = trade_rl
include_external_packages = True

[importlinter:contract:layers]
name = Trade RL responsibility layers
type = layers
layers =
    trade_rl.cli
    trade_rl.workflows
    trade_rl.integrations
    trade_rl.serving
    trade_rl.learning
    trade_rl.rl
    trade_rl.risk
    trade_rl.simulation
    trade_rl.strategies
    trade_rl.data
    trade_rl.evaluation
    trade_rl.release
    trade_rl.artifacts
    trade_rl.domain

[importlinter:contract:domain]
name = Domain remains standard-library only
type = forbidden
source_modules =
    trade_rl.domain
forbidden_modules =
    numpy
    gymnasium
    stable_baselines3
    torch
    trade_rl.artifacts
    trade_rl.release
    trade_rl.evaluation
    trade_rl.data
    trade_rl.strategies
    trade_rl.simulation
    trade_rl.risk
    trade_rl.rl
    trade_rl.learning
    trade_rl.serving
    trade_rl.integrations
    trade_rl.workflows
    trade_rl.cli

[importlinter:contract:serving]
name = Serving cannot import training or workflows
type = forbidden
source_modules =
    trade_rl.serving
forbidden_modules =
    trade_rl.rl.training
    trade_rl.workflows
    trade_rl.integrations
    stable_baselines3

[importlinter:contract:release]
name = Release remains verification-only and below serving
type = forbidden
source_modules =
    trade_rl.release
forbidden_modules =
    trade_rl.evaluation
    trade_rl.data
    trade_rl.strategies
    trade_rl.simulation
    trade_rl.risk
    trade_rl.rl
    trade_rl.learning
    trade_rl.serving
    trade_rl.integrations
    trade_rl.workflows
    trade_rl.cli
    stable_baselines3
    sb3_contrib
    torch

[importlinter:contract:learning-frameworks]
name = Learning contracts cannot depend on SB3 frameworks
type = forbidden
source_modules =
    trade_rl.learning
forbidden_modules =
    stable_baselines3
    sb3_contrib
    torch

[importlinter:contract:workflow-frameworks]
name = Workflows cannot directly import model frameworks
type = forbidden
allow_indirect_imports = True
source_modules =
    trade_rl.workflows
forbidden_modules =
    stable_baselines3
    sb3_contrib
    torch

[importlinter:contract:training-core]
name = Training core remains framework independent
type = forbidden
source_modules =
    trade_rl.rl.training
forbidden_modules =
    gymnasium
    stable_baselines3
    sb3_contrib
    torch

[importlinter:contract:offline-signers]
name = Runtime and training paths cannot import offline signers
type = forbidden
source_modules =
    trade_rl.serving
    trade_rl.integrations
    trade_rl.rl
    trade_rl.workflows.training_run
    trade_rl.workflows.market_walk_forward
forbidden_modules =
    trade_rl.release.offline_signing
    trade_rl.release.offline_keys
    trade_rl.release.offline_approval
    trade_rl.evaluation.offline_confirmation
    trade_rl.workflows.offline_selection_approval
