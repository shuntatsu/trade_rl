[importlinter]
root_package = trade_rl
include_external_packages = True

[importlinter:contract:layers]
name = Trade RL responsibility layers
type = layers
layers =
    trade_rl.cli
    trade_rl.workflows
    trade_rl.integrations
    trade_rl.serving
    trade_rl.rl
    trade_rl.risk
    trade_rl.simulation
    trade_rl.strategies
    trade_rl.data
    trade_rl.evaluation
    trade_rl.artifacts
    trade_rl.domain

[importlinter:contract:domain]
name = Domain remains standard-library only
type = forbidden
source_modules =
    trade_rl.domain
forbidden_modules =
    numpy
    gymnasium
    stable_baselines3
    torch
    trade_rl.artifacts
    trade_rl.evaluation
    trade_rl.data
    trade_rl.strategies
    trade_rl.simulation
    trade_rl.risk
    trade_rl.rl
    trade_rl.serving
    trade_rl.integrations
    trade_rl.workflows
    trade_rl.cli

[importlinter:contract:serving]
name = Serving cannot import training or workflows
type = forbidden
source_modules =
    trade_rl.serving
forbidden_modules =
    trade_rl.rl.training
    trade_rl.workflows
    trade_rl.integrations
    stable_baselines3

[importlinter:contract:workflow-frameworks]
name = Workflows cannot directly import model frameworks
type = forbidden
allow_indirect_imports = True
source_modules =
    trade_rl.workflows
forbidden_modules =
    stable_baselines3
    sb3_contrib
    torch

[importlinter:contract:training-core]
name = Training core remains framework independent
type = forbidden
source_modules =
    trade_rl.rl.training
forbidden_modules =
    gymnasium
    stable_baselines3
    sb3_contrib
    torch
